#include <stdio.h>

int main() {
    int n, arr[100], i, j, gap, temp;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    for(gap = n/2; gap > 0; gap /= 2) {
        for(i = gap; i < n; i++) {
            temp = arr[i];
            for(j = i; j >= gap && arr[j-gap] > temp; j -= gap) {
                arr[j] = arr[j-gap];
            }
            arr[j] = temp;
        }
    }

    printf("Sorted array:\n");
    for(i = 0; i < n; i++)
        printf("%d ", arr[i]);

    return 0;
}


Input
Enter number of elements: 5
Enter elements:
23 12 1 8 34

Output
Sorted array:
1 8 12 23 34