#include <stdio.h>
int main(){
    int a[50],b[50],c[100],n1,n2,i;

    scanf("%d",&n1);
    for(i=0;i<n1;i++) scanf("%d",&a[i]);

    scanf("%d",&n2);
    for(i=0;i<n2;i++) scanf("%d",&b[i]);

    for(i=0;i<n1;i++) c[i]=a[i];
    for(i=0;i<n2;i++) c[n1+i]=b[i];

    printf("Merged: ");
    for(i=0;i<n1+n2;i++) printf("%d ",c[i]);
}


Input
Enter N1: 3 → 1 2 3
Enter N2: 2 → 4 5

Output
Merged array: 1 2 3 4 5