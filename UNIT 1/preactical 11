#include <stdio.h>
int main(){
    int a[3][3],b[3][3],c[3][3]={0},i,j,k;

    for(i=0;i<3;i++)
        for(j=0;j<3;j++)
            scanf("%d",&a[i][j]);

    for(i=0;i<3;i++)
        for(j=0;j<3;j++)
            scanf("%d",&b[i][j]);

    for(i=0;i<3;i++)
        for(j=0;j<3;j++)
            for(k=0;k<3;k++)
                c[i][j]+=a[i][k]*b[k][j];

    for(i=0;i<3;i++){
        for(j=0;j<3;j++)
            printf("%d ",c[i][j]);
        printf("\n");
    }
}


Input
Matrix A:
1 2 3
4 5 6
7 8 9

Matrix B:
1 0 0
0 1 0
0 0 1

Output
Result:
1 2 3
4 5 6
7 8 9