#include <stdio.h>
int main(){
    char str[100];
    int i,space=0,vowel=0;

    gets(str);

    for(i=0;str[i]!='\0';i++){
        if(str[i]==' ') space++;
        if(str[i]=='a'||str[i]=='e'||str[i]=='i'||str[i]=='o'||str[i]=='u'||
           str[i]=='A'||str[i]=='E'||str[i]=='I'||str[i]=='O'||str[i]=='U')
           vowel++;
    }

    printf("Spaces=%d Vowels=%d",space,vowel);
}


Input
String: hello world

Output
Spaces = 1
Vowels = 3