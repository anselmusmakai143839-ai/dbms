#include <stdio.h>
int main(){
    int n,i,a[100],b[100];
    scanf("%d",&n);
    for(i=0;i<n;i++) scanf("%d",&a[i]);

    for(i=0;i<n;i++) b[i]=a[i];

    printf("Copied array: ");
    for(i=0;i<n;i++) printf("%d ",b[i]);
}


input
Enter N: 3
Elements: 1 2 3

Output
Copied array: 1 2 3