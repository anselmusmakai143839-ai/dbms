#include <stdio.h>
#include <stdlib.h>

int main(){
    int n;
    printf("Enter N: ");
    scanf("%d",&n);

    int *a = (int*)malloc(n*sizeof(int));
    int sum=0;

    for(int i=0;i<n;i++){
        scanf("%d",&a[i]);
        sum+=a[i];
    }

    printf("Sum=%d Avg=%.2f",sum,(float)sum/n);
}


Input:
3
10 20 30

Output:
Sum=60 Avg=20.00