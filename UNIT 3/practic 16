#include <stdio.h>
#include <string.h>

int main(){
    char s[50];
    scanf("%s",s);

    int len=strlen(s),flag=1;
    for(int i=0;i<len/2;i++){
        if(s[i]!=s[len-i-1]){
            flag=0; break;
        }
    }

    if(flag) printf("Palindrome");
    else printf("Not Palindrome");
}