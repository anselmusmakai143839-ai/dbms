#include <stdio.h>
#include <stdlib.h>

int main(){
    int n,even=0,odd=0;
    scanf("%d",&n);

    int *a = malloc(n*sizeof(int));

    for(int i=0;i<n;i++){
        scanf("%d",&a[i]);
        if(a[i]%2==0) even+=a[i];
        else odd+=a[i];
    }

    printf("Even=%d Odd=%d",even,odd);
}