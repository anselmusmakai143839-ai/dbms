 }

    // input + addition
    for(int i=0;i<r;i++)
        for(int j=0;j<c;j++){
            scanf("%d",&a[i][j]);
        }

    for(int i=0;i<r;i++)
        for(int j=0;j<c;j++){
            scanf("%d",&b[i][j]);
            sum[i][j]=a[i][j]+b[i][j];
        }

    printf("Result:\n");
    for(int i=0;i<r;i++){
        for(int j=0;j<c;j++)
            printf("%d ",sum[i][j]);
        printf("\n");
    }
