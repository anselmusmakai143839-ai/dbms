#include <stdlib.h>

int prime(int n){
    if(n<2) return 0;
    for(int i=2;i<n;i++)
        if(n%i==0) return 0;
    return 1;
}

int main(){
    int n,sum=0;
    scanf("%d",&n);

    int *a = malloc(n*sizeof(int));

    for(int i=0;i<n;i++){
        scanf("%d",&a[i]);
        if(prime(a[i])) sum+=a[i];
    }

    printf("Sum of primes=%d",sum);
}