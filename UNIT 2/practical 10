struct date {
    int d,m,y;
};

struct student {
    int roll;
    char name[20];
    struct date doj;
};

int main(){
    struct student s;

    printf("Enter roll, name, date(dd mm yyyy): ");
    scanf("%d %s %d %d %d",
          &s.roll,s.name,&s.doj.d,&s.doj.m,&s.doj.y);

    printf("\nStudent Info:\n");
    printf("%d %s %d/%d/%d",
           s.roll,s.name,s.doj.d,s.doj.m,s.doj.y);
}


Input
101 John 10 5 2020

Output
101 John 10/5/2020