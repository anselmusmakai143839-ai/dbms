#include <stdio.h>

int main() {
    FILE *fp;
    char ch;

    fp = fopen("sample.txt", "r");

    fseek(fp, 5, SEEK_SET);
    printf("Position: %ld\n", ftell(fp));

    ch = fgetc(fp);
    printf("Character: %c\n", ch);

    rewind(fp);
    printf("After rewind: %ld\n", ftell(fp));

    fclose(fp);
    return 0;
}



Input (sample.txt)
ABCDEFGH

Output
Position: 5
Character: F
After rewind: 0